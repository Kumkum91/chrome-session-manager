{
  "manifest_version": 3,
  "name": "Tab Session Manager",
  "version": "1.0",
  "description": "Save and restore Chrome tab sessions.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "128": "icons/icon192.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "128": "icons/icon192.png"
  },
  "permissions": ["tabs", "storage"]
}